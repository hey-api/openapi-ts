{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI 3.1.0 parameter content query json example",
    "version": "1"
  },
  "paths": {
    "/foo": {
      "get": {
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "active": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "default": {
            "description": "OK"
          }
        }
      },
      "post": {
        "parameters": [
          {
            "name": "input",
            "in": "query",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "default": {
            "description": "OK"
          }
        }
      }
    }
  }
}
