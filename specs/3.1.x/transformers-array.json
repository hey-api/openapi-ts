{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI 3.1.0 transformers array example",
    "version": "1"
  },
  "paths": {
    "/foo": {
      "get": {
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "foo": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "baz": {
                            "type": "string",
                            "format": "date-time"
                          }
                        },
                        "required": ["baz"]
                      }
                    },
                    "bar": {
                      "type": "array",
                      "items": {
                        "type": "integer",
                        "format": "int64"
                      }
                    },
                    "baz": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  },
                  "required": ["foo", "bar", "baz"]
                }
              }
            }
          }
        }
      }
    }
  }
}
