{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI 3.1.0 array parameter with deepObject style",
    "version": "1"
  },
  "paths": {
    "/foo": {
      "get": {
        "parameters": [
          {
            "name": "products",
            "in": "query",
            "style": "deepObject",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "default": {
            "description": "OK"
          }
        }
      }
    }
  }
}
