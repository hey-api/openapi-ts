---
import { fetchIssueReactions } from '@/utils/github';

type Props =
  | { status: 'beta'; issueNumber?: number; repo?: string }
  | { status: 'planned' | 'in-progress'; issueNumber: number; repo?: string };

const {
  issueNumber,
  repo = 'hey-api/openapi-ts',
  status = 'planned',
} = Astro.props;

if (import.meta.env.DEV && status !== 'beta' && issueNumber === undefined) {
  throw new Error(`[FeatureStatus] issueNumber is required for status="${status}"`);
}

const issueHref = issueNumber !== undefined
  ? `https://github.com/${repo}/issues/${issueNumber}`
  : `https://github.com/${repo}/issues`;

const statusConfig: Record<Required<Props>['status'], { label: string; linkLabel: string; }> = {
  'beta': { label: 'Beta', linkLabel: 'Leave feedback' },
  'in-progress': { label: 'In Progress', linkLabel: 'Track progress' },
  'planned': { label: 'Planned', linkLabel: 'Vote to prioritize' },
};

const { label, linkLabel } = statusConfig[status];
const reactions = issueNumber !== undefined
  ? await fetchIssueReactions(repo, issueNumber)
  : [];
---

<div class="feature-status">
  <span class="status-badge">{label}</span>
  <span class="status-links">
    <a href={issueHref} rel="noreferrer" target="_blank">{linkLabel}</a>
    <span aria-hidden="true">·</span>
    <a href="/openapi-ts/community/contributing">Contribute</a>
  </span>
  {reactions.length > 0 && (
    <span class="reactions" aria-label="Issue reactions">
      {reactions.map(({ emoji, count }) => (
        <a class="reaction" href={issueHref} rel="noreferrer" target="_blank">
          <span class="reaction-emoji" aria-hidden="true">{emoji}</span>
          <span class="reaction-count">{count}</span>
        </a>
      ))}
    </span>
  )}
</div>

<style>
  .feature-status {
    align-items: center;
    background-color: color-mix(in srgb, var(--vp-c-brand-1) 8%, transparent);
    border-left: 3px solid var(--vp-c-brand-1);
    border-radius: 0 0.25rem 0.25rem 0;
    display: flex;
    font-size: 0.8125rem;
    gap: 0.75rem;
    margin-block-end: 1rem;
    margin-block-start: -1rem;
    padding: 0.5rem 0.75rem;
  }

  .status-badge {
    background-color: color-mix(in srgb, var(--vp-c-brand-1) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--vp-c-brand-1) 35%, transparent);
    border-radius: 999px;
    color: var(--vp-c-brand-2);
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    white-space: nowrap;
  }

  .status-links {
    align-items: center;
    color: var(--sl-color-text-accent);
    display: flex;
    flex: 1;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .reactions {
    align-items: center;
    display: flex;
    gap: 0.375rem;
    margin-left: auto;
  }

  .reaction {
    align-items: center;
    background-color: color-mix(in srgb, var(--vp-c-brand-1) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--vp-c-brand-1) 25%, transparent);
    border-radius: 999px;
    color: var(--vp-c-brand-2);
    display: inline-flex;
    font-size: 0.75rem;
    font-weight: 500;
    gap: 0.3rem;
    line-height: 1.6;
    padding: 0.1rem 0.5rem 0.1rem 0.375rem;
    text-decoration: none;
    transition: background-color 150ms ease, border-color 150ms ease;
    white-space: nowrap;
  }

  .reaction:hover {
    background-color: color-mix(in srgb, var(--vp-c-brand-1) 18%, transparent);
    border-color: color-mix(in srgb, var(--vp-c-brand-1) 45%, transparent);
  }

  .reaction-emoji {
    font-size: 0.875rem;
    line-height: 1;
  }

  .reaction-count {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
  }
</style>
