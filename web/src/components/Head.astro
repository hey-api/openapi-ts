---
import openapiTypeScriptImage from '@/assets/openapi-ts-hero-640w.png';
import openapiPythonImage from '@/assets/openapi-python-hero-640w.png';

const { entry, head } = Astro.locals.starlightRoute;
const site = Astro.site;

const currentPath = Astro.url.pathname.replace(/\/$/, '');
const isOpenapiPythonDocs = currentPath.startsWith('/docs/openapi/python');
const defaultOgImage = isOpenapiPythonDocs
  ? openapiPythonImage.src
  : openapiTypeScriptImage.src;

const ogImage = entry.data.og?.image
  ? entry.data.og.image.src
  : defaultOgImage;

const version = entry.data.custom?.versionSynonym ?? entry.data.custom?.version;

let pageRank: string | undefined;
if (version && version.startsWith('v')) {
  pageRank = version.slice(1);
}

const extraHead: typeof head = [
  { tag: 'meta', attrs: { property: 'og:type', content: 'website' } },
  { tag: 'meta', attrs: { property: 'og:image', content: ogImage } },
];

if (pageRank !== undefined && pageRank !== '0') {
  extraHead.push({ tag: 'meta', attrs: { name: 'algolia-page-rank', content: pageRank } });
}
---

{[...head, ...extraHead].map(({ tag: Tag, attrs, content }) => {
  if (attrs?.rel === 'shortcut icon') return;
  return <Tag {...attrs} set:html={content} />
})}

{site && (
  <link
    rel="alternate"
    type="text/markdown"
    href={new URL(`${entry.id}.md`, site).toString()}
  />
)}
