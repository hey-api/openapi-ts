---
import { fetchSponsorGoal } from '@/utils/github';

const goal = await fetchSponsorGoal();
const pct = goal ? Math.min(100, Math.max(0, goal.percentComplete)) : 0;

const label = `${pct}% funded`;
const labelHover = `Fund your stack`;
const title = `${goal?.title} (${pct}% of goal reached)`;
const ariaLabel = `Sponsor Hey API — ${pct}% of goal`;
---

{goal && (
  <a
    href="/sponsors"
    class="sponsor-goal"
    title={title}
    aria-label={ariaLabel}
  >
    <span class="sponsor-goal__label">
      <span class="label-default">{label}</span>
      <span class="label-hover">{labelHover}</span>
    </span>
    <span class="sponsor-goal__track" role="progressbar" aria-valuenow={pct} aria-valuemin={0} aria-valuemax={100} style={`--pct: ${pct}%; --pct-num: ${pct}`}>
      <span class="sponsor-goal__fill"></span>
      <span class="sponsor-goal__extension"></span>
    </span>
  </a>
)}

<style>
  .sponsor-goal {
    align-items: center;
    border-radius: 6px;
    border: 1px solid transparent;
    color: var(--sl-color-text);
    display: inline-flex;
    flex-direction: column;
    font-size: var(--sl-text-xs, 0.75rem);
    font-weight: 500;
    gap: 0.25rem;
    letter-spacing: 0.01em;
    padding: 0.3rem 0.6rem;
    text-decoration: none;
    width: 9rem;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .sponsor-goal:hover,
  .sponsor-goal:focus-visible {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent-high, var(--sl-color-accent));
    outline: none;
  }

  .sponsor-goal__label {
    display: grid;
    white-space: nowrap;
  }

  .label-default,
  .label-hover {
    align-items: center;
    display: flex;
    gap: 0.3rem;
    grid-area: 1 / 1;
    justify-content: center;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .label-hover {
    opacity: 0;
    transform: translateY(0.3rem);
  }

  .sponsor-goal:hover .label-default,
  .sponsor-goal:focus-visible .label-default {
    opacity: 0;
    transform: translateY(-0.3rem);
  }

  .sponsor-goal:hover .label-hover,
  .sponsor-goal:focus-visible .label-hover {
    opacity: 1;
    transform: translateY(0);
  }

  .heart {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }

  .sponsor-goal__track {
    background: var(--sl-color-hairline, color-mix(in srgb, var(--sl-color-text) 15%, transparent));
    border-radius: 999px;
    display: block;
    height: 4px;
    position: relative;
    width: 100%;
  }

  .sponsor-goal__fill {
    background: hsl(calc(var(--pct-num, 0) * 1.2), 65%, 50%);
    border-radius: 999px;
    display: block;
    height: 100%;
    width: var(--pct, 0%);
    transition: width 0.4s ease;
  }

  .sponsor-goal__extension {
    border-radius: 999px;
    height: 100%;
    left: var(--pct, 0%);
    opacity: 0;
    position: absolute;
    top: 0;
    width: 1.5rem;
    background: hsl(calc(var(--pct-num, 0) * 1.2), 80%, 70%);
    transition: opacity 0.2s ease;
  }

  .sponsor-goal:hover .sponsor-goal__fill,
  .sponsor-goal:focus-visible .sponsor-goal__fill {
    animation: extend-pulse 1.5s ease-in-out infinite;
  }

  @keyframes extend-pulse {
    0%, 100% { width: var(--pct, 0%); }
    50% { width: min(100%, calc(var(--pct, 0%) + 8%)); }
  }
</style>
