{
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "other": "on",
    "strings": "on"
  },
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "search.exclude": {
    "**/*-lock.yaml": true,
    "**/*-lock.json": true,
    "**/*.log": true,
    "**/*.map": true,
    "**/dist": true,
    "**/.mypy_cache": true,
    "**/__snapshots__": true,
    "**/coverage": true,
    "**/openapi-python-tests/**/.gen": true,
    "**/openapi-ts-tests/**/generated": true,
    "**/openapi-ts-tests/**/.gen": true,
    "**/*.tsbuildinfo": true,
    "**/.astro/data-store.json": true,
    "**/.vercel/output": true
  },
  "workbench.editorAssociations": {
    "*.svg": "default"
  },
  "js/ts.experimental.useTsgo": true,
  "js/ts.preferences.autoImportFileExcludePatterns": ["dist/**"],
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": ["^(node:)?os$"],
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "vitest.rootConfig": "vitest.config.ts",
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
